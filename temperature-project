import processing.core.PApplet;
import java.util.Scanner;
import java.io.File;
import java.util.*;

public class Sketch extends PApplet {
    ArrayList<DayRecord> days;
    String[] months = { "Jan","Feb","Mar","Apr","May","Jun","Jul","Aug","Sep","Oct","Nov","Dec"};
    //int minTemp, minTemp;
    public void settings() {
        size(600, 600);
    }

    public void setup() {
        
        days = new ArrayList<DayRecord>();
        //Reads data from temps.txt file
        try {
            Scanner sc = new Scanner(new File("temps.txt"));

            while (sc.hasNextLine()) {
                //read the next line of text
                String line = sc.nextLine();

                //Find temperature value using position of space and degree symbol
                int from = line.lastIndexOf(" ")+1;
                int to = line.indexOf("°");
                int temperature = Integer.parseInt(line.substring(from, to));

                //Extract month name
                int firstSpace = line.indexOf(" ");
                String  month = (line.substring(0, firstSpace));

                //Extract day number 
                int secondSpace = line.indexOf(" ", firstSpace+1);
                int day = Integer.parseInt(line.substring(firstSpace+1, secondSpace));

                //Store data inside DayRecord object
                days.add(new DayRecord(month, day, temperature));
            }
            sc.close();
        }
        catch (Exception e) {
            e.printStackTrace();
        }
        noLoop();
    }

    public void draw() {
        drawRec();
    }

    public void drawRec(){
        int cHeight = height / 12;
        background(220);
        noStroke();
        

        //Draw month labers on the left side
        for( int i = 0; i < months.length; i++){
            float y = i * cHeight + cHeight/2;
            fill(0);
            textSize(12);
            textAlign(LEFT, CENTER);
            text(months[i], 15, y);
        }


        //Find min and max from color scaling
        int maxTemp = days.get(0).getTemp();
        int minTemp = days.get(0).getTemp();
        
        //Helps with finding min and max
        for(DayRecord d : days){
            if(d.getTemp() < minTemp){
                minTemp = d.getTemp();
            }
            if(d.getTemp() > maxTemp){
                maxTemp = d.getTemp();
            }
        }
        
        //Calculate rect width and height
        int cWidth = width/28;

        //Draw Rectangles 
        for(int j = 0; j<days.size(); j++){
            DayRecord d = days.get(j);

            //Find month row index
            int monthIndex = 0;
            for(int i = 0; i<months.length; i++){
                if(d.getMonth().equals(months[i])){
                    monthIndex = i;
                    break;
                }
            }
            //set color based on temperature
            fill(d.getColor(minTemp, maxTemp));

            // x position 
            int x = 50+(int)((d.getDay()-1)*cWidth);
            //y position
            int y = monthIndex*cHeight;
            //draw small rectangles
            rect(x, y, cWidth, cHeight);
        
        }
    }
}
